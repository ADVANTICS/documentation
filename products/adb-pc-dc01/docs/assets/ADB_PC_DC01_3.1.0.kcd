        </Consumer>
      </Signal>
    </Message>
    <Message id="0x820012" name="Converter_Control" length="1" format="extended">
      <Notes>Converter control command</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="enable" offset="0">
        <Notes>Enable the power converter 
                       enable takes priority over sleep
                </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
      </Signal>
      <Signal name="sleep" offset="1">
        <Notes>Ask the converter to go to sleep mode 

                        the converter will go to sleep mode only from standby mode
                        enable  takes priority over sleep
                </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
      </Signal>
    </Message>
    <Message id="0x820013" name="Converter_Power_Info" length="6" format="extended">
      <Notes>Real-time power converter performance metrics

                  Some signals are still experimental and may change in the future.
            </Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="load" offset="0" length="8">
        <Notes>Current load utilization 
                        
                    Actual power demand relative to Power_capability limit.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255" unit="%"/>
      </Signal>
      <Signal name="efficiency" offset="8" length="8">
        <Notes>Converter efficiency</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255" unit="%"/>
      </Signal>
      <Signal name="Power_capability" offset="16" length="16">
        <Notes> Maximum deliverable power based on configured setpoints (V * A).
             
                    Examples:
                        - 1000V * 50A = 50kW &#10003; (within limits)
                        - 1500V * 200A = 300kW &#8594; capped at 100kW (converter maximum)
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="kw"/>
      </Signal>
      <Signal name="low_power_input" offset="32" length="16">
        <Notes>low-voltage input (typically 24V)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="v"/>
      </Signal>
    </Message>
    <Message id="0x820010" name="Status" length="8" format="extended">
      <Notes>General Status of the power converter</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="State" offset="0" length="16">
        <Notes>Current operating state of the power converter.

                        Init: The converter is initializing. It will transition to Standby if initialization succeeds, 
                        or to Critical/Error if it fails.
                        Standby: The converter is idle and ready to be turned-on if conditions are met (no errors, no warnings).
                        Turning_on: The converter is powering up.
                        Running: The converter is actively operating.
                        Turning_off: The converter is shutting down.
                        Error: A recoverable fault has occurred.
                        Critical: A critical fault has occurred, requiring reboot (please inform Advantics).
                        God: For Developer (mode cannot be used by customers).
                        Sleeping: The converter is in sleeping mode in order to save energy.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="65535"/>
        <LabelSet>
          <Label name="init" value="0"/>
          <Label name="standby" value="1"/>
          <Label name="turning_on" value="2"/>
          <Label name="running" value="3"/>
          <Label name="turning_off" value="4"/>
          <Label name="error" value="5"/>
          <Label name="critical" value="6"/>
          <Label name="god" value="7"/>
          <Label name="sleeping" value="8"/>
        </LabelSet>
      </Signal>
      <Signal name="flag_enable" offset="16">
        <Notes>Indicates  that the converter is asked to be enabled.
                        once condition are meet (no wanring nor error) the converter will do to turning-on
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_ready" offset="17">
        <Notes>Indicates that a valid setpoint has been received and conditions are met to turn on the converter.</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_energized" offset="18">
        <Notes>Indicates that the converter is energized (internal and external &gt; 24V)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_busy" offset="19">
        <Notes>Indicates that the converter is in a transition state (init, turning on, or turning off). Some commands may be ignored during this step.</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_sleep" offset="20">
        <Notes>Indicates that the converter is asked to operating in energy-saving (sleep) mode.

                        the converter will go in sleeping mode
                        Turning on the power converter in eco mode may take a little more time (feature not yet implemented).
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_warning" offset="24">
        <Notes>Indicates that one or more warnings are active.

                        When in standby mode, all warnings must be cleared before turning on the power converter.
                        If "Enable" is set in "Converter_Control", the power converter will turn on as soon as all warnings are cleared.
                        The system may be operating in degraded mode.
                        During operation (Running), the power converter will continue to run, but degraded performance may be expected.
                        Refer to the "Warning" message for more details.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_degraded" offset="25">
        <Notes>Indicates that the converter is running in degraded performance mode 

                    This can be due to high temperature.
                    Refer to the "Warning" message for more details.

                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_error" offset="26">
        <Notes>Indicates that one or more Errors are active.

                    When in standby mode, all errors must be cleared before turning on the power converter.
                    If "Enable" is set in "Converter_Control", the power converter will turn on as soon as all warnings are cleared.
                    During operation (Running), the power converter will turn off.
                    Errors can be cleared using "Clear_Interlock" signals from the "Fault_Control" message.
                    The system may be operating in degraded mode.
                    Refer to the "Errors" or "Faults" message for more details.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_factory" offset="48">
        <Notes>Indicates that the converter is operating in factory or service mode. 

                        This flag should not be active for customers
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
      <Signal name="flag_god_mode" offset="49">
        <Notes>Indicates that the converter is in special diagnostic or unrestricted mode (god mode).
                    
                        This flag should not be active for customers

                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
      </Signal>
    </Message>
    <Message id="0x8200F0" name="_fms_state" length="8" format="extended">
      <Notes>FSM  status - DEBUG ONLY, not for customer visibility</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="init" offset="0" length="8">
        <Notes>state: INIT (initialization phase)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="ready" offset="16" length="8">
        <Notes>state: READY </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="turned_on" offset="32" length="8">
        <Notes>state: TURNED_ON</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="turned_off" offset="40" length="8">
        <Notes>state: TURNED_OFF</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="bleeding" offset="48" length="8">
        <Notes>state: BLEEDING</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
    </Message>
    <Message id="0x820011" name="Faults" length="8" format="extended">
      <Notes>Fault status bitfield (1-bit flags per fault type)

                    Severity levels and clearing:
                    - Tripped: Can be cleared using "Clear_Interlock" signals from "Fault_Control" message.
                    - Critical: Requires system reboot (contact Advantics support).
                    - Error: Can be cleared using "Clear_Interlock" signals from "Fault_Control" message.

                    State machine behavior:
                    - Standby: All errors must be cleared before power-on is allowed. if "Enable"  is active, the converter will 
                      turns on when all faults/warnings are cleared.
                    - Running: Any Error fault triggers the turning-off sequence shutdown. And any Critical fault trigger immediate shutdown
                
            </Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="internal" offset="0">
        <Notes>Internal interlock trip 
                    
                    An internal issue has arisen.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Tripped" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="external" offset="1">
        <Notes>External interlock trip

                    Common causes:
                    - External emergency stop button pressed
                    - External safety interlock opened (door switch, guard, etc.)
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Tripped" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="system" offset="2">
        <Notes>Critical system fault detected (contact Advantics support)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="EEPROM_failure" offset="3">
        <Notes>EEPROM read/write failure (contact Advantics support)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="wrong_nfo" offset="4">
        <Notes>Invalid configuration detected (contact Advantics support)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="Measurement_system_failure" offset="5">
        <Notes>Voltage/current measurement system fault (contact Advantics support)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="PLL_not_locked" offset="6">
        <Notes>PLL not locked (contact Advantics support)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="overtemperature" offset="7">
        <Notes>Over-temperature condition detected 

                    Cooling plate temperature exceeded 75&#176;C threshold
                    Can be cleared once temperature is bellow 75&#176;C. check message "Converter_Temperature"

                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="fan_stuck" offset="8">
        <Notes>Cooling fan stalled or not running

                        The system may overheat(contact Advantics support if the problem persist)
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="dead_module" offset="9">
        <Notes>Lost communication between the ADM-CS and one or more ADM-PC</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="keep_alive_not_serv_internal" offset="10">
        <Notes>Internal ADM-PC keep-alive watchdog timeout. Was not served in time by ADM-CS</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="error_temperature" offset="11">
        <Notes>Temperature sensor error. One or more sensors are unavailable or reporting invalid data.</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_modules_ready" offset="12">
        <Notes>One or more internal modules (ADM-PC) are NOT ready</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_modules_can_api" offset="13">
        <Notes>One or more internal modules (ADM-PC) have mismatched CAN API versions expected by ADM-CS
                        
                        check message "info_can_api_error" for more detail
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_modules_missing" offset="14">
        <Notes>One or more internal modules (ADM-PC) are  missing (not detect on can bus)

                        check message "info_adm_pc" for more detail
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_modules_wrong" offset="15">
        <Notes>One or more internal modules (ADM-PC) are not compatible with the NFO of ADM-CS</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_modules_stack" offset="16">
        <Notes>One or more internal modules (ADM-PC) don't respect the required stack position for the NFO of ADM-CS</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_modules_init" offset="17">
        <Notes>One or more internal modules (ADM-PC) failed at init (ready flag)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="wrong_revision" offset="18">
        <Notes>One or more internal modules (ADM-PC) don't have the required revision for the NFO of ADM-CS </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="v_in_low" offset="19">
        <Notes>24V input voltage too low

                        Increase voltage and/or current before clearing the error.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="v_in_critical" offset="20">
        <Notes>24V input voltage critically low, 

                        Increase voltage and/or current and reboot the power converter
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Critical" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="keep_alive_not_serv" offset="21">
        <Notes>keep-alive watchdog timeout

                    Upper controller did not service the keepalive watchdog in time.
                    Check "Interface_Status" message and increase "keep_Alive_Period" if needed
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Error" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_a" offset="22">
        <Notes>Internal interlock trip 
                    
                    An internal issue has arisen.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Tripped" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_b" offset="23">
        <Notes>Internal interlock trip 
                    
                    An internal issue has arisen.
                </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Tripped" value="1"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x820015" name="Interface_Status" length="3" format="extended">
      <Notes>interface status</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="Broadcast_Group" offset="0" length="8">
        <Notes>The broadcast group that the module belongs to. Broadcast group 0 implies that the module is not part of a broadcast group. </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="30"/>
      </Signal>
      <Signal name="keep_Alive" offset="8" length="4">
        <Notes>keep alive requires the supervisory/upper controller to send a heartbeat message at regular intervals</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="15"/>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved" offset="12" length="4">
        <Notes>reserved for future usage</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="15"/>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="keep_Alive_Period" offset="16" length="8">
        <Notes>The maximum period of the keep alive message. If the time between two heart-beat messages is longer than this value, the power converter will go to Error. This only applies when the Heartbeat signal is Enabled</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="25.5" unit="s"/>
      </Signal>
    </Message>
    <Message id="0x820016" name="Keep_Alive_Control" length="2" format="extended">
      <Notes>Configure the Heartbeat for the Module. The 'Heartbeat Period' signal only apply if the heartbeat signals are enabled</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Enable" offset="0">
        <Notes>Enable/Disable the Heartbeat feature of the Module</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved" offset="1">
        <Notes>Reserved for future usage</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="Period" offset="8" length="8">
        <Notes>Set the maximum period of the Heartbeat message. If the time between two heart-beat messages is longer than this value, the power converter will go to Error.</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="25.5" unit="s"/>
      </Signal>
    </Message>
    <Message id="0x820017" name="Converter_Temperature" length="8" format="extended">
      <Notes>Readouts of the power converter temperature sensors</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="Cooling_plate" offset="0" length="16">
        <Notes>Temperature of the cooling plate</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
      <Signal name="Magnetics" offset="16" length="16">
        <Notes>Highest measured temp of magnetics</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
      <Signal name="Transistors" offset="32" length="16">
        <Notes>Highest measured temp of transistors</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
      <Signal name="reserved" offset="48" length="16">
        <Notes>reserved for future usage</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
    </Message>
    <Message id="0x820018" name="Converter_Fans" length="6" format="extended">
      <Notes>Readouts from the power converter's internal fans.</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="A_rpm" offset="0" length="16">
        <Notes>Measured speed of Fan A</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="65535" unit="rpm"/>
      </Signal>
      <Signal name="A_pwm" offset="16" length="8">
        <Notes>Fan A target speed in percentage (0 to 100%)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255" unit="%"/>
      </Signal>
      <Signal name="B_rpm" offset="24" length="16">
        <Notes>Measured speed of Fan B</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="65535" unit="rpm"/>
      </Signal>
      <Signal name="B_pwm" offset="40" length="8">
        <Notes>Fan B target speed in percentage (0 to 100%)</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255" unit="%"/>
      </Signal>
    </Message>
    <Message id="0x820019" name="Keep_Alive_Feed" length="1" format="extended">
      <Notes>keep alive feeding</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="feed" offset="0">
        <Notes>The value doesn't matter here, it is only used to feed the keepalive</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
      </Signal>
    </Message>
    <Message id="0x8200F1" name="_interlocks_status" length="3" format="extended">
      <Notes>INTERNAL DEBUG ONLY - Customer systems should NOT monitor or display this message
                    
                    Split power converter interlock status
            </Notes>
      <Producer>
