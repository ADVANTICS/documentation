  <Bus name="ADB_PC_DC01">
    <Message id="0x800040" name="DC01_Mode_Set" length="2" format="extended">
      <Notes>Set the mode of AC01</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="mode" offset="0" length="8">
        <Notes>require mode</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="B_port_Controlled" value="0"/>
          <Label name="A_port_Controlled" value="1"/>
          <Label name="Bleeding" value="2"/>
        </LabelSet>
      </Signal>
      <Signal name="connection" offset="8" length="8">
        <Notes>require connection</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="forced_serial" value="0"/>
          <Label name="forced_parallel" value="1"/>
          <Label name="automatic" value="2"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x800041" name="DC01_Mode_Applied" length="2" format="extended">
      <Notes>read back the modes</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="mode" offset="0" length="8">
        <Notes>actual mode</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="B_side_Controlled" value="0"/>
          <Label name="A_side_Controlled" value="1"/>
          <Label name="Bleeding" value="2"/>
        </LabelSet>
      </Signal>
      <Signal name="connection" offset="8" length="8">
        <Notes>connection mode</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="open" value="0"/>
          <Label name="serial" value="1"/>
          <Label name="parallel" value="2"/>
        </LabelSet>
      </Signal>
    </Message>
