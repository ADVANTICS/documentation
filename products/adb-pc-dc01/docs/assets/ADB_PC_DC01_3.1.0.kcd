        </Consumer>
      </Signal>
      <Signal name="Reset_Processor" offset="1">
        <Notes>Reset the device DSP</Notes>
        <Consumer>
          <NodeRef id="3"/>
        </Consumer>
      </Signal>
      <Signal name="Trip_Interlock" offset="2">
        <Notes>Trip the internal Interlock</Notes>
        <Consumer>
