        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="raw" value="0"/>
          <Label name="value" value="1"/>
          <Label name="prob_offset" value="2"/>
          <Label name="prob_scale_factor" value="3"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x820064" name="_Calibration_reading" length="8" format="extended">
      <Notes>FACTORY USE ONLY - Calibration reading (requires factory mode)

                Should only be used in factory, not customers. For calibration issues, contact Advantics support</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="index" offset="0" length="8">
        <Notes>index of the device that need reading </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="unvalid" value="0"/>
          <Label name="voltage_sensor_b" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="select" offset="8" length="8">
        <Notes>select what value to read</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="raw" value="0"/>
          <Label name="value" value="1"/>
          <Label name="prob_offset" value="2"/>
          <Label name="prob_scale_factor" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="calibration_status" offset="16">
        <Notes>select what value to read</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="bad" value="0"/>
          <Label name="ok" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved" offset="17" length="7">
        <Notes>select what value to read</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="127"/>
      </Signal>
      <Signal name="value" offset="24" length="32">
        <Notes>require calibration valut </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.0001" min="-214748.3648" max="214748.3647"/>
      </Signal>
    </Message>
    <Message id="0x820060" name="_Factory_Config" length="8" format="extended">
      <Notes>FACTORY USE ONLY - Factory configuration (requires factory mode)

                    Should only be used in factory, not customers. In case of issues, contact Advantics support.
            </Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="select" offset="0" length="8">
        <Notes>set ID (will apply setted revision and variant as well)</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="invalid" value="0"/>
          <Label name="cs" value="1"/>
          <Label name="adb" value="2"/>
          <Label name="reset" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="set_id" offset="8" length="8">
        <Notes>set ID, need factory mode = 1 (will change revision and variant as well)</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="set_revision" offset="16" length="8">
        <Notes>set revision, need factory mode = 1 , applied if set_id is valid</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="set_variant" offset="24" length="8">
        <Notes>set variant, need factory mode = 1, applied if set_id is valid</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
    </Message>
    <Message id="0x820065" name="_Factory_Debug_cmd" length="8" format="extended">
      <Notes>FACTORY USE ONLY - Factory debug command (requires factory mode)

                    Should only be used in factory, not customers. In case of issues, contact Advantics support.
            </Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="god_mode" offset="0">
        <Notes>If set to 1, module will enter in god mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
      </Signal>
      <Signal name="internal_power_a" offset="1">
        <Notes>If set to 1, ADM-PC on side A will be turned off</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="on" value="0"/>
          <Label name="off" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_power_b" offset="2">
        <Notes>If set to 1, ADM-PC on side B will be turned off</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="on" value="0"/>
          <Label name="off" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="offset_stack_internal" offset="8" length="8">
        <Notes>Allow to generate a virtual offset in the stack address for internal ADM-PC</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255" unit="offset"/>
      </Signal>
    </Message>
    <Message id="0x820092" name="_error_code" length="4" format="extended">
      <Notes>DEBUG</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="error" offset="0" length="8">
        <Notes>error code</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" min="-128" max="127" unit="offset"/>
      </Signal>
    </Message>
  </Bus>
</NetworkDefinition>
