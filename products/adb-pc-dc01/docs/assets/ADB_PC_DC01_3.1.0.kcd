    <Message id="0x800062" name="_Calibration_writing" length="6" format="extended">
      <Notes>Calibration control (factory mode need to be set)</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="index" offset="0" length="8">
        <Notes>index of the device that nee calibration (0 is unvalid) </Notes>
        <Consumer>
          <NodeRef id="4"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="invalid" value="0"/>
          <Label name="voltage_sensor_b" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="select" offset="8" length="8">
        <Notes>select what value to set</Notes>
        <Consumer>
          <NodeRef id="4"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="invalid" value="0"/>
          <Label name="prob_offset" value="1"/>
          <Label name="prob_scale_factor" value="2"/>
        </LabelSet>
      </Signal>
      <Signal name="value" offset="16" length="32">
        <Notes>require calibration valut </Notes>
        <Consumer>
          <NodeRef id="4"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.0001" min="-214748.3648" max="214748.3647"/>
      </Signal>
    </Message>
    <Message id="0x800063" name="_Calibration_reading_cmd" length="2" format="extended">
      <Notes>Calibration reading cmd (factory mode need to be set)</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="index" offset="0" length="8">
        <Notes>index of the device that need reading </Notes>
        <Consumer>
