        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Tripped" value="0"/>
          <Label name="Clear" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="i" offset="3">
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Tripped" value="0"/>
          <Label name="Clear" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="x" offset="4">
        <Consumer>
