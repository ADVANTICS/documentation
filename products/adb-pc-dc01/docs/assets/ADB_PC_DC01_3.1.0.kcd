    <Message id="0x820036" name="A_Port_Controls" length="4" format="extended">
      <Notes>The control the behaviour of the A Port of the DC01</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="external_precharge_status" offset="0" length="16">
        <Notes> Inform the DC01 about the external precharge status

                an external precharge is needed for A side control. 

                External precharge should monitor for 'A_Port_Feedback' 'precharge_status' 

                this flag should be set to off in other 'precharge_status'
        </Notes>
        <Consumer>
          <NodeRef id="2"/>
        </Consumer>
        <Value max="65535"/>
        <LabelSet>
          <Label name="disabled" value="0"/>
          <Label name="in_progress" value="1"/>
          <Label name="done" value="2"/>
          <Label name="failed" value="3"/>
        </LabelSet>
      </Signal>
    </Message>
