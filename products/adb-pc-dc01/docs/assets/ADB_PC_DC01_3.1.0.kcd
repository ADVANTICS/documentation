          <Label name="INITIALISING" value="1"/>
          <Label name="IN_PROGRESS" value="2"/>
          <Label name="DONE" value="3"/>
          <Label name="FAILED" value="4"/>
        </LabelSet>
      </Signal>
    </Message>
