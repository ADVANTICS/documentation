          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="raw" value="0"/>
          <Label name="value" value="1"/>
          <Label name="prob_offset" value="2"/>
          <Label name="prob_scale_factor" value="3"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x800064" name="_Calibration_reading" length="8" format="extended">
      <Notes>Calibration reading cmd (factory mode need to be set)</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="index" offset="0" length="8">
        <Notes>index of the device that need reading </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="unvalid" value="0"/>
          <Label name="voltage_sensor_b" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="select" offset="8" length="8">
        <Notes>select what value to read</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="raw" value="0"/>
          <Label name="value" value="1"/>
          <Label name="prob_offset" value="2"/>
          <Label name="prob_scale_factor" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="calibration_status" offset="16">
        <Notes>select what value to read</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="bad" value="0"/>
          <Label name="ok" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved" offset="17" length="7">
        <Notes>select what value to read</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="127"/>
      </Signal>
      <Signal name="value" offset="24" length="32">
        <Notes>require calibration valut </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.0001" min="-214748.3648" max="214748.3647"/>
      </Signal>
    </Message>
    <Message id="0x800060" name="_Factory_Config" length="8" format="extended">
      <Notes>factory setting of controller and boxs</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="select" offset="0" length="8">
        <Notes>set ID, need factory mode = 1 (will change revision and variant as well)</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="invalid" value="0"/>
          <Label name="cs" value="1"/>
          <Label name="adb" value="2"/>
          <Label name="reset" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="set_id" offset="8" length="8">
        <Notes>set ID, need factory mode = 1 (will change revision and variant as well)</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="set_revision" offset="16" length="8">
        <Notes>set revision, need factory mode = 1 , applied if set_id is valid</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="set_variant" offset="24" length="8">
        <Notes>set variant, need factory mode = 1, applied if set_id is valid</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
    </Message>
    <Message id="0x800065" name="_Factory_Debug_cmd" length="8" format="extended">
      <Notes>factory debug cmd, need factory mode flag set to 1</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="god_mode" offset="0">
        <Notes>Customers MUST NOT USE this bit. If set to 1, module will enter in factory mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
      </Signal>
      <Signal name="internal_power_a" offset="1">
        <Notes>Customers MUST NOT USE this bit. If set to 1, module will enter in factory mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="on" value="0"/>
          <Label name="off" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_power_b" offset="2">
        <Notes>Customers MUST NOT USE this bit. If set to 1, module will enter in factory mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="on" value="0"/>
          <Label name="off" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="offset_stack_internal" offset="8" length="8">
        <Notes>Customers MUST NOT USE this bit. need factory mode = 1 </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255" unit="offset"/>
      </Signal>
    </Message>
  </Bus>
</NetworkDefinition>
