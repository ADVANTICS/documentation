<NetworkDefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://kayak.2codeornot2code.org/1.0" xsi:schemaLocation="Definition.xsd">
  <Document name="Some Document Name">some text</Document>
  <Node name="User" id="1"/>
  <Node name="ADB_PC_DC01" id="2"/>
  <Node name="ADB_PC_BASE" id="3"/>
  <Node name="ADB_PC_BOX" id="4"/>
  <Bus name="ADB_PC_DC01">
    <Message id="0x820040" name="DC01_Mode_Set" length="2" format="extended">
      <Notes>Configure DC01 operating mode and connection topology</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="mode" offset="0" length="8">
        <Notes>Requested operating mode

            B_port_Controlled (0): B-side voltage controlled to setpoint, requires VA input present
            A_port_Controlled (1): A-side voltage controlled (not yet supported)
            Bleeding (2): Discharge internal capacitors/remaining charge

            changing mode can only be done when the power converter is not "Enable"
        </Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="B_port_Controlled" value="0"/>
          <Label name="A_port_Controlled" value="1"/>
          <Label name="Bleeding" value="2"/>
        </LabelSet>
      </Signal>
      <Signal name="connection" offset="8" length="8">
        <Notes>Requested internal contactor configuration

            forced_serial (0): VB bellow (VA * 2) required
            forced_parallel (1): VB bellow VA required  
            automatic (2): Converter auto-selects topology (experimental), automatic is 
            not allowed on A side controlled

            changing connection can only be done when the power converter is not "Enable"
        </Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="forced_serial" value="0"/>
          <Label name="forced_parallel" value="1"/>
          <Label name="automatic" value="2"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x820041" name="DC01_Mode_Applied" length="2" format="extended">
      <Notes>DC01 actual operating mode (readback)</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="mode" offset="0" length="8">
        <Notes>Currently applied operating mode

                changing mode can only be done when the power converter is not "Enable"
        </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="B_side_Controlled" value="0"/>
          <Label name="A_side_Controlled" value="1"/>
          <Label name="Bleeding" value="2"/>
        </LabelSet>
      </Signal>
      <Signal name="connection" offset="8" length="8">
        <Notes>Currently applied contactor topology

           changing connection can only be done when the power converter is not "Enable"
        </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="open" value="0"/>
          <Label name="serial" value="1"/>
          <Label name="parallel" value="2"/>
        </LabelSet>
      </Signal>
    </Message>
