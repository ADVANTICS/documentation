    <Message id="0x820043" name="DC01_warning" length="8" format="extended">
      <Notes>DC01 warning flags, it need to be cleared to "Enable" the power converter</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="MODE_NOT_SUPPORTED" offset="0">
        <Notes>Warning: Requested operating mode is not supported</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_A_LOW" offset="10">
        <Notes>Warning: Port A voltage is below the minimum threshold</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_A_HIGH" offset="11">
        <Notes>Warning: Port A voltage exceeds the maximum threshold</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="NEED_UPDATE" offset="12">
        <Notes>Warning: Power converter firmware update is required</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="EXTERNAL_PRECHARGE_NOT_DISABLED" offset="13">
        <Notes>Warning: External precharge is expected to de disable bit isn't</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_B_NOT_ZERO" offset="14">
        <Notes>Warning: V measure on B side is expected to be 0V</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_B_LOW" offset="15">
        <Notes>Warning : voltage on b side is too low</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x820044" name="DC01_info" length="8" format="extended">
      <Notes>DC01 info flags</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="BLEEDING_DONE" offset="0">
        <Notes>Info: Bleeding resistor discharge completed successfully</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CONTACTORS_CONNECTION_SERIAL" offset="1">
        <Notes>Info: Contactors are connected in series</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CONTACTORS_CONNECTION_PARALLEL" offset="2">
        <Notes>Info: Contactors are connected in parallel</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CONTACTORS_CONNECTION_OPEN" offset="3">
        <Notes>Info: All contactors are open</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CONNECTION_MANAGER_RQ_CHANGE" offset="4">
        <Notes>Info: Connection manager requests topology change</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="VB_LIMITED_BY_VA" offset="5">
        <Notes>Info: VA is not high enough to reach targeted VB</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CURRENT_LIMIT" offset="6">
        <Notes>Info: Current limit has been reached</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="VB_TO_HIGH_FOR_SELECTED_MODE" offset="7">
        <Notes>Info:  vb is too high for the current selected mode</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CURRENT_LIMITED_BY_POWER" offset="8">
        <Notes>Info: current is limited because max power is reached</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x820020" name="B_Port_Setpoints" length="6" format="extended">
      <Notes>The setpoints control the behaviour of the B Port of the DC01</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Voltage" offset="0" length="16">
        <Notes>Control the target B port voltage. This voltage will be maintained as long as the current required to do so is smaller than the current limits specified in this message</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="V"/>
      </Signal>
      <Signal name="Positive_Current_Limit" offset="16" length="16">
        <Notes>The maximum current that the DC01 will source on the B port</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
      <Signal name="Negative_Current_Limit" offset="32" length="16">
        <Notes>The maximum current that the AC01 will sink into the B port</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
    </Message>
    <Message id="0x820021" name="B_Port_Applied_Setpoints" length="8" format="extended">
      <Notes>The setpoints that are currently used by the DC01. This message allows to validate that the setpoints have been properly applied.</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="Voltage" offset="0" length="16">
        <Notes>The voltage target of the B port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="V"/>
      </Signal>
      <Signal name="Positive_Current_Limit" offset="16" length="16">
        <Notes>The maximum current that the DC01 will source on the B Port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
      <Signal name="Negative_Current_Limit" offset="32" length="16">
        <Notes>The maximum amount of current that the DC01 will sink into the B port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
    </Message>
    <Message id="0x820022" name="B_Port_Droop_Setpoints" length="8" format="extended">
      <Notes>Setpoints for applying Droop on the DC Port B. Droop is needed for paralleling multiple DC01

            it is recommended to always have a bit of droop (0.4) and adjust it depending of the topology
      </Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Positive_Current_Droop" offset="0" length="16">
        <Notes>The droop resistance to apply for current flowing out of the DC port (DC current is positive)</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.01" max="655.35" unit="Ohm"/>
      </Signal>
      <Signal name="Negative_Current_Droop" offset="16" length="16">
        <Notes>The droop resistance to apply for current flowing in to the DC Port B (DC current is negative)</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.01" max="655.35" unit="Ohm"/>
      </Signal>
      <Signal name="Enable" offset="32">
        <Notes>Enable DC Droop. If this feature is enabled the output voltage of the DC port  Bvaries with output current.</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="Reserved" offset="33" length="31">
        <Notes>This space is reserved. This region should contain only '0's</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="3"/>
        </Consumer>
        <Value max="2147483647"/>
      </Signal>
    </Message>
    <Message id="0x820023" name="B_Port_Applied_Droop_Setpoints" length="5" format="extended">
      <Notes>Droop setpoints that are applied by the DC01 on port B </Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="Positive_Current_Droop" offset="0" length="16">
        <Notes>The droop resistance applied for current flowing out of the DC port B (DC current is positive)</Notes>
