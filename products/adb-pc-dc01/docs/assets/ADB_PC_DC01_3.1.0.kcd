    <Message id="0x800015" name="Interface_Status" length="3" format="extended">
      <Notes>interface status</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="Broadcast_Group" offset="0" length="8">
        <Notes>The broadcast group that the module belongs to. Broadcast group 0 implies that the module is not part of a broadcast group. </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="30"/>
      </Signal>
      <Signal name="keep_Alive" offset="8" length="4">
        <Notes>keep alive requires the supervisory controller to send a heartbeat message at regular intervals</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="15"/>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved" offset="12" length="4">
        <Notes>If this signal and the 'keep alive' is enabled, violating the heartbeat will trip the interlock, shutting down all connected power converters</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="15"/>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="keep_Alive_Period" offset="16" length="8">
        <Notes>The maximum period of the keep alive message. If the time between two heart-beat messages is longer than this value, the module ceases operation. This only applies when the Heartbeat signal is Enabled</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="25.5" unit="s"/>
      </Signal>
    </Message>
    <Message id="0x800016" name="Keep_Alive_Control" length="2" format="extended">
      <Notes>Configure the Heartbeat for the Module. The 'Trip interlock' and 'Heartbeat Period' only apply if the heartbeat signals are enabled</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Enable" offset="0">
        <Notes>Enable/Disable the Heartbeat feature of the Module</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved" offset="1">
        <Notes>Set if the external interlock should be tripped if a heartbeat is not received within the configured period. If this signal is enabled the interlock is triped and the module is disabled. If this signal is set to Disabled, the interlock like will not be tripped but the module will cease operation</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="Period" offset="8" length="8">
        <Notes>Set the maximum period of the Heartbeat message. If the time between two heart-beat messages is longer than this value, the module ceases operation.</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="25.5" unit="s"/>
      </Signal>
    </Message>
    <Message id="0x800017" name="Converter_Temperature" length="8" format="extended">
      <Notes>Readouts of the converter temperature sensors</Notes>
      <Producer>
        <NodeRef id="4"/>
      </Producer>
      <Signal name="Cooling_plate" offset="0" length="16">
        <Notes>Temperature of the cooling plate</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
      <Signal name="Magnetics" offset="16" length="16">
        <Notes>Highest mesured temp of magnetics</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
      <Signal name="Transistors" offset="32" length="16">
        <Notes>Highest mesured temp of transistors</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
      <Signal name="RESERVED" offset="48" length="16">
        <Notes>Lowest measured temp internally</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.01" min="-327.68" max="327.67" unit="&#176;C"/>
      </Signal>
    </Message>
