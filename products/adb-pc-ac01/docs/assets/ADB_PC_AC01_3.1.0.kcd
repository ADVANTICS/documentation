    <Message id="0x810060" name="_Factory_Config_0__BOX" length="8" format="extended">
      <Notes>factory setting of controller and boxs</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="select_0__BOX" offset="0" length="8">
        <Notes>set ID, need factory mode = 1 (will change revision and variant as well)</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="invalid" value="0"/>
          <Label name="cs" value="1"/>
          <Label name="adb" value="2"/>
          <Label name="reset" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="set_id_0__BOX" offset="8" length="8">
        <Notes>set ID, need factory mode = 1 (will change revision and variant as well)</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="set_revision_0__BOX" offset="16" length="8">
        <Notes>set revision, need factory mode = 1 , applied if set_id is valid</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
      <Signal name="set_variant_0__BOX" offset="24" length="8">
        <Notes>set variant, need factory mode = 1, applied if set_id is valid</Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255"/>
      </Signal>
    </Message>
    <Message id="0x810065" name="_Factory_Debug_cmd_0__BOX" length="8" format="extended">
      <Notes>factory debug cmd, need factory mode flag set to 1</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="god_mode_0__BOX" offset="0">
        <Notes>Customers MUST NOT USE this bit. If set to 1, module will enter in factory mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
      </Signal>
      <Signal name="internal_power_a_0__BOX" offset="1">
        <Notes>Customers MUST NOT USE this bit. If set to 1, module will enter in factory mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="on" value="0"/>
          <Label name="off" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="internal_power_b_0__BOX" offset="2">
        <Notes>Customers MUST NOT USE this bit. If set to 1, module will enter in factory mode. </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="on" value="0"/>
          <Label name="off" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="offset_stack_internal_0__BOX" offset="8" length="8">
        <Notes>Customers MUST NOT USE this bit. need factory mode = 1 </Notes>
        <Consumer>
          <NodeRef id="4"/>
        </Consumer>
        <Value max="255" unit="offset"/>
      </Signal>
    </Message>
  </Bus>
