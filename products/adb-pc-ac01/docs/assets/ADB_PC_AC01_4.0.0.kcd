    <Message id="0x810003" name="ADB_CAN_API_Version" length="3" format="extended">
      <Notes>This message declares the version of the API that is provided by the device. The version follows newer convention, as this file is an API definition, patch does not apply</Notes>
      <Producer>
        <NodeRef id="3"/>
      </Producer>
      <Signal name="Major" offset="0" length="8">
        <Notes>The Major version number. This number increases if there are backwards incompatible changes</Notes>
        <Consumer>
