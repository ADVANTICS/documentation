    <Message id="0x810043" name="AC01_warning" length="8" format="extended">
      <Notes>AC01 warning flags, it need to be cleared to "Enable" the power converter</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="grid_not_supported" offset="0">
        <Notes>Warning: Grid is not supported 

      
          3-Phase 230V (line-to-neutral) / 400V (line-to-line), 50Hz
          3-Phase 277V (line-to-neutral) / 480V (line-to-line), 60Hz
          3-Phase 120V (line-to-neutral) / 208V (line-to-line), 60Hz
      </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="grid_not_existing" offset="1">
        <Notes>Warning: The converter is not connected to existing grid </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="grid_selection_wrong" offset="2">
        <Notes>Warning: grid selection is wrong

            converter see an existing grid and the selected grid mode is different 
      </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="reserved_3" offset="3">
        <Notes>reserved</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_SET_DC_BELOW_AC" offset="4">
        <Notes>Warning: DC voltage setpoint is lower than the measured AC voltage

              It needs to follow this equation::
                    Vset DC &gt; VAC rms * sqrt(2) * 2 + 20
      </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_DC_BELOW_AC" offset="5">
        <Notes>Warning: DC voltage measured is too low to generate AC voltage

              It needs to follow this equation::
                    Vset DC &gt; VAC rms * sqrt(2) * 2 + 20
      </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="AFE_DROOP_NOT_ENABLE" offset="15">
        <Notes>Warning: AFE droop control is disabled but expected to be enabled</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="MODE_NOT_SUPPORTED" offset="16">
        <Notes>Warning: The selected operating mode is not supported</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_A_LOW" offset="17">
        <Notes>Warning: Port A voltage is below the minimum operating threshold</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_A_HIGH" offset="18">
        <Notes>Warning: Port A voltage exceeds the maximum operating threshold</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_B_LOW" offset="19">
        <Notes>Warning: Port A voltage is below the minimum operating threshold</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="V_B_HIGH" offset="20">
        <Notes>Warning: Port A voltage exceeds the maximum operating threshold</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Warning" value="1"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x810044" name="AC01_info" length="8" format="extended">
      <Notes>Info: Informational status and operating conditions</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="BLEEDING_DONE" offset="1">
        <Notes>Info: Bleeding process completed successfully</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CURRENT_LIMIT" offset="2">
        <Notes>Info: Current limit has been reached</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="CURRENT_LIMITED_BY_POWER" offset="3">
        <Notes>Info: Output current is limited because the maximum power is reached</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="VB_LIMITED_BY_VA" offset="4">
        <Notes>Info: Output voltage VB is limited because input voltage VA is insufficient</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <LabelSet>
          <Label name="Clear" value="0"/>
          <Label name="Info" value="1"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x810020" name="DC_Ports_Setpoints" length="6" format="extended">
      <Notes>The setpoints control the behaviour of the DC Port of the AC01. The AC01 operates this port in CVCC mode</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Voltage" offset="0" length="16">
        <Notes>Control the target dc side voltage. This voltage will be maintained as long as the current required to do so is smaller than the current limits specified in this message</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="V"/>
      </Signal>
      <Signal name="Positive_Current_Limit" offset="16" length="16">
        <Notes>The maximum current that the AC01 will source on the DC Port</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
      <Signal name="Negative_Current_Limit" offset="32" length="16">
        <Notes>The maximum current that the AC01 will sink into the DC Port</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
    </Message>
    <Message id="0x810021" name="DC_Port_Applied_Setpoints" length="8" format="extended">
      <Notes>The setpoints that are currently used by the AC01. This message allows to validate that the setpoints have been properly applied.</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="Voltage" offset="0" length="16">
        <Notes>The voltage target of the DC port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="V"/>
      </Signal>
      <Signal name="Positive_Current_Limit" offset="16" length="16">
        <Notes>The maximum current that the AC01 will source on the DC Port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
      <Signal name="Negative_Current_Limit" offset="32" length="16">
        <Notes>The maximum amount of current that the AC01 will sink into the DC port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
    </Message>
    <Message id="0x810024" name="DC_Port_Measurements" length="4" format="extended">
      <Notes>Measurements of the DC Bus</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="Voltage" offset="0" length="16">
        <Notes>Voltage on the DC Port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="V"/>
      </Signal>
      <Signal name="Current" offset="16" length="16">
        <Notes>Current through the DC Port</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="0.1" min="-3276.8" max="3276.7" unit="A"/>
      </Signal>
    </Message>
    <Message id="0x810022" name="DC_Port_Droop_Setpoints" length="8" format="extended">
      <Notes>Setpoints for applying Droop on the DC Port. Droop is needed for paralleling multiple AC01</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Positive_Current_Droop" offset="0" length="16">
        <Notes>The droop resistance to apply for current flowing out of the DC port (DC current is positive)</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.01" max="655.35" unit="Ohm"/>
      </Signal>
      <Signal name="Negative_Current_Droop" offset="16" length="16">
        <Notes>The droop resistance to apply for current flowing in to the DC Port (DC current is negative)</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.01" max="655.35" unit="Ohm"/>
      </Signal>
      <Signal name="Enable" offset="32">
        <Notes>Enable DC Droop. If this feature is enabled the output voltage of the DC port varies with output current.</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
          <NodeRef id="4"/>
        </Consumer>
        <LabelSet>
          <Label name="Disabled" value="0"/>
          <Label name="Enabled" value="1"/>
        </LabelSet>
      </Signal>
      <Signal name="Reserved" offset="33" length="31">
        <Notes>This space is reserved. This region should contain only '0's</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
          <NodeRef id="3"/>
        </Consumer>
        <Value max="2147483647"/>
      </Signal>
    </Message>
