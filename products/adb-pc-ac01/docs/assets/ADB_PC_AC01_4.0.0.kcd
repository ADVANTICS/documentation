<NetworkDefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://kayak.2codeornot2code.org/1.0" xsi:schemaLocation="Definition.xsd">
  <Document name="Some Document Name">some text</Document>
  <Node name="User" id="1"/>
  <Node name="ADB_PC_AC01" id="2"/>
  <Node name="ADB_PC_BASE" id="3"/>
  <Node name="ADB_PC_BOX" id="4"/>
  <Bus name="ADB_PC_AC01">
    <Message id="0x810040" name="AC01_Mode_Set" length="1" format="extended">
      <Notes>Configure AC01 operating mode</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="mode" offset="0" length="8">
        <Notes>Requested operating mode

            DC_Controlled (0): DC side voltage controlled to setpoint, requires AC side input present
            AC_Controlled (1): AC side voltage controlled (not yet supported)
            Bleeding (2): Discharge internal capacitors/remaining charge

            changing mode can only be done when the power converter is not "Enable"</Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="DC_Controlled" value="0"/>
          <Label name="AC_Controlled" value="1"/>
          <Label name="Bleeding" value="2"/>
        </LabelSet>
      </Signal>
    </Message>
    <Message id="0x810041" name="AC01_Mode_Applied" length="1" format="extended">
      <Notes>AC01 actual operating mode (readback)</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="mode" offset="0" length="8">
        <Notes>Currently applied operating mode

                changing mode can only be done when the power converter is not "Enable"
          </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="255"/>
        <LabelSet>
          <Label name="DC_Controlled" value="0"/>
          <Label name="AC_Controlled" value="1"/>
          <Label name="Bleeding" value="2"/>
        </LabelSet>
      </Signal>
    </Message>
