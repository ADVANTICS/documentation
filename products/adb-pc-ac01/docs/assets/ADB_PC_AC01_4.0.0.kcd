    <Message id="0x810030" name="AC_Port_Setpoints" length="8" format="extended">
      <Notes>Setpoints to apply to the AC Port</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="grid" offset="0" length="16">
        <Notes>select grid type that should be generated. All grids are 3-phase.

                FOLLOWING (0): Follows existing grid if compatible (see below).
                230V_400V_50HZ (1): 3-Phase 230V (line-to-neutral) / 400V (line-to-line), 50Hz
                277V_480V_60HZ (2): 3-Phase 277V (line-to-neutral) / 480V (line-to-line), 60Hz
                120V_208V_60HZ (3): 3-Phase 120V (line-to-neutral) / 208V (line-to-line), 60Hz
        </Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="65535"/>
        <LabelSet>
          <Label name="FOLLOWING" value="0"/>
          <Label name="230V_400V_50HZ" value="1"/>
          <Label name="277V_480V_60HZ" value="2"/>
          <Label name="120V_208V_60HZ" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="Q" offset="16" length="16">
        <Notes>Reactive Power of the AC port. Positive values cause the AC01 to behave inductively, negative values cause the AC01 to behave capacitively</Notes>
        <Consumer>
          <NodeRef id="2"/>
        </Consumer>
        <Value type="signed" slope="10" min="-327680" max="327670" unit="VAR"/>
      </Signal>
      <Signal name="RMS_Phase_Current_Limit" offset="32" length="16">
        <Notes>The maximum RMS current that the AC01 will supply at its AC terminals.
                This value limits the the magnitute of the AC current and applies
                symmetrically to both source and sink currents. This limit applies to
                the current carried by a single phase.
        </Notes>
        <Consumer>
          <NodeRef id="2"/>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="A"/>
      </Signal>
    </Message>
    <Message id="0x810031" name="AC_Port_Applied_Setpoints" length="8" format="extended">
      <Notes>Setpoints that are currently being applied to the the AC Port</Notes>
      <Producer>
        <NodeRef id="2"/>
      </Producer>
      <Signal name="grid" offset="0" length="16">
        <Notes>select grid type that should be generated. All grids are 3-phase.
                        
                FOLLOWING (0): Follows existing grid if compatible (see below).
                230V_400V_50HZ (1): 3-Phase 230V (line-to-neutral) / 400V (line-to-line), 50Hz
                277V_480V_60HZ (2): 3-Phase 277V (line-to-neutral) / 480V (line-to-line), 60Hz
                120V_208V_60HZ (3): 3-Phase 120V (line-to-neutral) / 208V (line-to-line), 60Hz
        </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value max="65535"/>
        <LabelSet>
          <Label name="FOLLOWING" value="0"/>
          <Label name="230V_400V_50HZ" value="1"/>
          <Label name="277V_480V_60HZ" value="2"/>
          <Label name="120V_208V_60HZ" value="3"/>
        </LabelSet>
      </Signal>
      <Signal name="Q" offset="16" length="16">
        <Notes>Reactive Power of the AC port. Positive values cause the AC01 to behave inductively, negative values cause the AC01 to behave capacitively</Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value type="signed" slope="10" min="-327680" max="327670" unit="VAR"/>
      </Signal>
      <Signal name="RMS_Phase_Current_Limit" offset="32" length="16">
        <Notes>The maximum RMS current that the AC01 will supply at its AC terminals.
                This value limits the the magnitute of the AC current and applies
                symmetrically to both source and sink currents. This limit applies to
                the current carried by a single phase.
        </Notes>
        <Consumer>
          <NodeRef id="1"/>
        </Consumer>
        <Value slope="0.1" max="6553.5" unit="A"/>
      </Signal>
    </Message>
