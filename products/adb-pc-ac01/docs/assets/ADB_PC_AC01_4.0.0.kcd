    <Message id="0x810014" name="Broadcast_Group_Control" length="1" format="extended">
      <Notes>Configure the broadcast group that the power converter belongs to.</Notes>
      <Producer>
        <NodeRef id="1"/>
      </Producer>
      <Signal name="Group_ID" offset="0" length="8">
